# ── AWS Credentials (from AWS Console → IAM → your user → Access keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ── Bedrock (same region as Lambda)
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# ── Pinecone (from pinecone.io → API Keys)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aarogya-index

# ── DynamoDB
DYNAMODB_SESSIONS_TABLE=aarogya-sessions
DYNAMODB_PROFILES_TABLE=aarogya-profiles

# ── S3
S3_BUCKET_NAME=aarogya-uploads

# ── Google Places API (for doctor finder)
GOOGLE_PLACES_API_KEY=

# ── App settings
APP_ENV=development
LOG_LEVEL=INFO
